# Copy this file to .env and fill in your values.
# Never commit .env — it is listed in .gitignore.

ANTHROPIC_API_KEY=sk-ant-api03-...

# Paths to H&M dataset files (download separately — see README)
CUSTOMER_REVIEWS_FILE=data/customer_reviews/Womens Clothing E-Commerce Reviews.csv
ARTICLES_FILE=data/product_discovery/articles.csv
TRANSACTIONS_FILE=data/product_discovery/transactions_train.csv
INVENTORY_SNAPSHOT_FILE=data/inventory_supply/inventory_snapshot.csv

# Optional: explicit path to SQLite database (default: data/retail.db)
SQLITE_DB=data/retail.db
